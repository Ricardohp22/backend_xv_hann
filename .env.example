# Copia a `.env` y ajusta valores. No subas `.env` al repositorio.

PORT=3000
# En local puedes usar 127.0.0.1; en Render suele omitirse (por defecto 0.0.0.0).
# HOST=0.0.0.0

# --- Local: conexión por variables (sin DATABASE_URL) ---
DB_USER=postgres
DB_HOST=localhost
DB_NAME=xv_mgmt
DB_PASSWORD=cambia_esto
DB_PORT=5432

# --- Render / nube: Render inyecta DATABASE_URL al vincular Postgres ---
# DATABASE_URL=postgresql://usuario:contraseña@host:5432/xv_mgmt
# Solo si necesitas desactivar SSL con una URL remota (caso raro en local):
# DB_SSL=false

# Orígenes permitidos para CORS, separados por coma (sin espacios o con espacios recortados).
# Ejemplo: https://tu-app.onrender.com,http://localhost:5173
# CORS_ORIGIN=
